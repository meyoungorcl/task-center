page 30 (
    name: Application Summary
    alias: APPLICATIONS
    title: Application Summary
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region application-summary-title (
        name: Application Summary Title
        title: Application Summary
        type: staticContent
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region applications (
        name: Application Summary
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.application_id,
                       t.team_name,
                       a.application_code,
                       a.application_name,
                       count(tsk.task_id) as task_count,
                       sum(case when s.status_code = 'BACKLOG' then 1 else 0 end) as backlog_tasks,
                       sum(case when s.status_code = 'NOT_STARTED' then 1 else 0 end) as not_started_tasks,
                       sum(case when s.status_code = 'IN_PROGRESS' then 1 else 0 end) as in_progress_tasks,
                       sum(case when s.status_code = 'IN_REVIEW' then 1 else 0 end) as in_review_tasks,
                       sum(case when s.status_code = 'BLOCKED' then 1 else 0 end) as blocked_tasks,
                       sum(case when s.status_code = 'COMPLETED' then 1 else 0 end) as completed_tasks,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION',
                           p_values => a.application_name
                       ) as task_count_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',Backlog'
                       ) as backlog_tasks_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',Not Started'
                       ) as not_started_tasks_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',In Progress'
                       ) as in_progress_tasks_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',In Review'
                       ) as in_review_tasks_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',Blocked'
                       ) as blocked_tasks_url,
                       apex_page.get_url(
                           p_page => 10,
                           p_clear_cache => '10',
                           p_items => 'P10_APPLICATION,P10_STATUS',
                           p_values => a.application_name || ',Completed'
                       ) as completed_tasks_url
                  from tsk_applications a
                  left join tsk_teams t
                    on t.team_id = a.owner_team_id
                  left join tsk_tasks tsk
                    on tsk.application_id = a.application_id
                  left join tsk_statuses s
                    on s.status_id = tsk.status_id
                 group by a.application_id,
                          t.team_name,
                          a.application_code,
                          a.application_name
                 order by t.team_name, a.application_name
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No application summary rows found.
        }
        advanced {
        }

        column APPLICATION_CODE (
            type: plainText
            heading {
                heading: Code
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column APPLICATION_ID (
            type: hidden
            heading {
                heading: Application Id
            }
            layout {
                sequence: 5
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column APPLICATION_NAME (
            type: plainText
            heading {
                heading: Application
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column BACKLOG_TASKS (
            type: plainText
            heading {
                heading: Backlog
                alignment: center
            }
            layout {
                sequence: 50
                columnAlignment: center
            }
            columnFormatting {
                htmlExpression: <a href="#BACKLOG_TASKS_URL#">#BACKLOG_TASKS#</a>
            }
            source {
                dataType: NUMBER
            }
            advanced {
