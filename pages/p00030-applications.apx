        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport primary (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn APPLICATION_CODE (
                sequence: 3
            )

            displayColumn APPLICATION_ID (
                sequence: 1
            )

            displayColumn APPLICATION_NAME (
                sequence: 4
            )

            displayColumn BACKLOG_TASKS (
                sequence: 6
            )

            displayColumn BACKLOG_TASKS_URL (
                sequence: 13
            )

            displayColumn BLOCKED_TASKS (
                sequence: 10
            )

            displayColumn BLOCKED_TASKS_URL (
                sequence: 17
            )

            displayColumn COMPLETED_TASKS (
                sequence: 11
