        }
        source {
            formRegion: @task-form
            column: TOPIC_GROUP_ID
            dataType: number
        }
        help {
            helpText: You can select an existing topic group or type a new topic group name. The new topic group will be added to the topic group list for future tasks.
        }
    )

    pageItem P11_TOPIC_GROUP_MANUAL (
