page 11 (
    name: Task
    alias: TASK
    title: Task
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region task-form (
        name: Task
        type: form
        source {
            location: localDatabase
            tableName: TSK_TASKS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
            ]
        }
    )

    pageItem P11_APPLICATION_ID (
        type: selectList
        label {
            label: Application
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select application_name as display_value,
                       application_id as return_value
                  from tsk_applications
                 where active_yn = 'Y'
                 order by application_name
                ```
        }
        layout {
            sequence: 100
            region: @task-form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @task-form
            column: APPLICATION_ID
            dataType: number
        }
    )

    pageItem P11_ASSIGNEES (
        type: selectMany
        label {
            label: Assignees
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select u.display_name as display_value,
                       tm.team_member_id as return_value
                  from tsk_team_members tm
                  join tsk_users u
                    on u.user_id = tm.user_id
                 where tm.active_yn = 'Y'
                   and u.active_yn = 'Y'
                   and (:P11_TEAM_ID is null or tm.team_id = :P11_TEAM_ID)
                 order by u.display_name
                ```
        }
        layout {
            sequence: 75
            region: @task-form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            valuePlaceholder: Not Assigned
        }
        sessionState {
            storage: request
        }
    )

    pageItem P11_COMPLEXITY_ID (
        type: selectList
        label {
            label: Complexity
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select complexity_name as display_value,
                       complexity_id as return_value
                  from tsk_complexities
                 where active_yn = 'Y'
                 order by display_seq, complexity_name
                ```
        }
        layout {
            sequence: 120
            region: @task-form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @task-form
            column: COMPLEXITY_ID
            dataType: number
        }
    )

    pageItem P11_DESCRIPTION (
