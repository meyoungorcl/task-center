    pageItem P41_TEAM_MEMBER_IDS (
        type: selectMany
        label {
            label: Team Members to Email
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select u.display_name || ' (' || u.email || ')' as display_value,
                       tm.team_member_id as return_value
                  from tsk_team_members tm
                  join tsk_users u
                    on u.user_id = tm.user_id
                 where tm.active_yn = 'Y'
                   and u.active_yn = 'Y'
                   and tm.team_id = :P41_TEAM_ID
                 order by u.display_name
                ```
        }
        layout {
            sequence: 55
            region: @email-schedule-form
            slot: regionBody
            columnSpan: 12
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        sessionState {
            storage: request
        }
