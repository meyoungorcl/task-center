    process send-daily-email-now (
        name: Send Daily Email Now
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    tsk_daily_email_pkg.send_daily_schedule(:P41_EMAIL_SCHEDULE_ID);
                end;
                ```
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Daily email queued
        }
        advanced {
            executionMappingIdentifier: 9990004100000002
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: SEND_NOW
        }
    )

