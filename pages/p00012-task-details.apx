    pageItem P12_APPLICATION_ID (
        type: selectList
        label {
            label: Application
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select application_name as display_value,
                       application_id as return_value
                  from tsk_applications
                 where active_yn = 'Y'
                 order by application_name
                ```
        }
        layout {
            sequence: 100
            region: @task-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @task-details
            column: APPLICATION_ID
            dataType: number
        }
    )

    pageItem P12_ASSIGNEES (
        type: selectMany
        label {
            label: Assignees
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select u.display_name as display_value,
                       tm.team_member_id as return_value
                  from tsk_team_members tm
                  join tsk_users u
                    on u.user_id = tm.user_id
                 where tm.active_yn = 'Y'
                   and u.active_yn = 'Y'
                   and (:P12_TEAM_ID is null or tm.team_id = :P12_TEAM_ID)
                 order by u.display_name
                ```
        }
        layout {
            sequence: 70
            region: @task-details
            slot: regionBody
            alignment: left
            columnSpan: 6
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        sessionState {
            storage: request
        }
    )

    pageItem P12_TOPIC_GROUP_IDS (
        type: selectMany
        label {
            label: Topic Groups
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select topic_name as display_value,
                       topic_group_id as return_value
                  from tsk_topic_groups
                 where active_yn = 'Y'
                    or exists (
                           select 1
                             from tsk_task_topic_groups ttg
                            where ttg.task_id = :P12_TASK_ID
                              and ttg.topic_group_id = tsk_topic_groups.topic_group_id
                       )
                 order by topic_name
                ```
        }
        layout {
            sequence: 75
            region: @task-details
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 6
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        sessionState {
            storage: request
        }
    )

