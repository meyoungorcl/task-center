page 12 (
    name: Task Details
    alias: TASK-DETAILS
    title: Task Details
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    javaScript {
        functionAndGlobalVarDeclaration:
            ```javascript-browser
            apex.jQuery(() => {
                const sizeEditUpdateDialog = () => {
                    const region = apex.jQuery("#edit-update-dialog, #R9990001200000201").first();
                    const dialog = region.closest(".ui-dialog");
                    if (dialog.length) {
                        dialog.css({
                            width: "min(960px, calc(100vw - 2rem))",
                            maxWidth: "calc(100vw - 2rem)"
                        });
                        region.css("width", "100%");
                        dialog.position({ my: "center", at: "center", of: window });
                    }
                };

                if ($v("P12_EDIT_UPDATE_ID")) {
                    const dialog = apex.jQuery("#edit-update-dialog, #R9990001200000201").first();
                    if (dialog.length) {
                        apex.theme.openRegion(dialog.attr("id"));
                        dialog.attr("aria-modal", "true");
                        setTimeout(sizeEditUpdateDialog, 0);
                    }
                }

                apex.jQuery(window).on("resize", () => {
                    if ($v("P12_EDIT_UPDATE_ID")) {
                        sizeEditUpdateDialog();
                    }
                });
            });
            ```
    }

    region task-detail-column (
        name: Task Detail Column
        type: staticContent
        layout {
            sequence: 10
            slot: body
            columnSpan: 7
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region audit (
        name: Audit
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @task-detail-column
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-collapsed
                t-Region--scrollBody
            ]
        }
        settings {
            outputAs: text
        }
    )

    region activity (
        name: Activity
        type: staticContent
        layout {
            sequence: 20
            slot: body
            startNewRow: false
            columnSpan: 5
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region change-log (
        name: Change Log
        type: themeTemplateComponent/comments
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select change_id,
                       apex_string.get_initials(nvl(changed_by, 'System')) as user_initials,
                       'u-color-' || ora_hash(nvl(changed_by, 'System'), 45) as user_css_class,
                       nvl(changed_by, 'System') as user_name,
                       initcap(replace(change_action, '_', ' ')) || ': ' ||
                           coalesce(change_note, field_name || ' changed', new_value) as comment_text,
                       changed_at as comment_date
                  from tsk_change_log
                 where task_id = :P12_TASK_ID
                 order by changed_at desc
                ```
            pageItemsToSubmit: P12_TASK_ID
        }
        layout {
            sequence: 20
            parentRegion: @task-detail-column
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-collapsed
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        componentAppearance {
            display: report
        }
        settings {
            commentText: COMMENT_TEXT
            userName: USER_NAME
            date: COMMENT_DATE
            displayAvatar: false
            style: chatSpeechBubbles
            applyThemeColors: false
        }
        messages {
            whenNoDataFound: No changes
            noDataFoundIcon: fa-comments-o fa-lg
        }

        column CHANGE_ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: CHANGE_ID
                dataType: number
            }
        )

        column COMMENT_DATE (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: COMMENT_DATE
                dataType: date
            }
            accessibility {
                valueIdentifiesRow: true
            }
            appearance {
                formatMask: SINCE
            }
        )

        column COMMENT_TEXT (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: COMMENT_TEXT
                dataType: varchar2
            }
        )

        column USER_CSS_CLASS (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: USER_CSS_CLASS
                dataType: varchar2
            }
        )

        column USER_INITIALS (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: USER_INITIALS
                dataType: varchar2
            }
        )

        column USER_NAME (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: USER_NAME
                dataType: varchar2
            }
            accessibility {
                valueIdentifiesRow: true
            }
        )

    )

    region task-details (
