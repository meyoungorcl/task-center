    region updates (
        name: Recent Updates
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select null as update_card,
                       tu.update_id,
                       apex_string.get_initials(nvl(u.display_name, tu.created_by)) as user_initials,
                       'u-color-' || ora_hash(nvl(u.display_name, tu.created_by), 45) as user_css_class,
                       nvl(u.display_name, tu.created_by) as user_name,
                       case
                           when regexp_like(
                                    dbms_lob.substr(tu.update_text, 4000, 1),
                                    '<(p|ul|ol|li|div|span|br|strong|em|s|h[1-6])([[:space:]>])',
                                    'i'
                                )
                           then dbms_lob.substr(tu.update_text, 4000, 1)
                           else dbms_lob.substr(
                                    apex_markdown.to_html(to_clob(dbms_lob.substr(tu.update_text, 4000, 1))),
                                    4000,
                                    1
                                )
                       end as comment_text,
                       tu.updated_at as comment_date,
                       apex_page.get_url(
                           p_page => 12,
                           p_request => 'EDIT_UPDATE',
                           p_items => 'P12_TASK_ID,P12_EDIT_UPDATE_ID',
                           p_values => :P12_TASK_ID || ',' || tu.update_id
                       ) as edit_url,
                       apex_page.get_url(
                           p_page => 12,
                           p_request => 'DELETE_UPDATE',
                           p_items => 'P12_TASK_ID,P12_DELETE_UPDATE_ID',
                           p_values => :P12_TASK_ID || ',' || tu.update_id
                       ) as delete_url
                  from tsk_task_updates tu
                  left join tsk_team_members tm
                    on tm.team_member_id = tu.team_member_id
                  left join tsk_users u
                    on u.user_id = tm.user_id
                 where tu.task_id = :P12_TASK_ID
                 order by tu.updated_at desc nulls last,
                          tu.update_id desc
                ```
            pageItemsToSubmit: P12_TASK_ID
        }
        layout {
            sequence: 30
            parentRegion: @activity
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--inline
                t-Report--stretch
            ]
        }
        messages {
            whenNoDataFound: No updates
        }
        heading {
            type: none
        }

        column UPDATE_CARD (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: " "
            }
            layout {
                sequence: 10
            }
            columnFormatting {
                htmlExpression:
                    ```html
                    <div style="border:1px solid var(--ut-component-border-color);border-radius:8px;padding:12px;margin-bottom:10px;background:var(--ut-component-background-color)">
                      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px">
                        <div style="font-weight:700">#USER_NAME#</div>
                        <div style="white-space:nowrap;color:var(--ut-component-text-muted-color);font-size:.82rem">#COMMENT_DATE#</div>
                      </div>
                      <div style="color:var(--ut-component-text-default-color)">#COMMENT_TEXT!RAW#</div>
                      <div style="margin-top:8px;display:flex;gap:8px;justify-content:flex-end">
                        <a href="#EDIT_URL#" class="t-Button t-Button--noLabel t-Button--icon t-Button--tiny" title="Edit update" aria-label="Edit update" aria-haspopup="dialog"><span class="fa fa-edit" aria-hidden="true"></span></a>
                        <a href="#DELETE_URL#" class="t-Button t-Button--noLabel t-Button--icon t-Button--tiny" title="Delete update" aria-label="Delete update" onclick="return confirm('Delete this update?');"><span class="fa fa-trash-o u-danger-text" aria-hidden="true"></span></a>
                      </div>
                    </div>
                    ```
            }
        )

        column COMMENT_DATE (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 70
            }
            source {
                databaseColumn: COMMENT_DATE
                dataType: date
            }
            appearance {
                formatMask: SINCE
            }
        )

        column COMMENT_TEXT (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 60
            }
            source {
                databaseColumn: COMMENT_TEXT
                dataType: varchar2
            }
        )

        column DELETE_URL (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 90
            }
        )

        column EDIT_URL (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 80
            }
        )

        column UPDATE_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 20
            }
        )

        column USER_CSS_CLASS (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 40
            }
            source {
                databaseColumn: USER_CSS_CLASS
                dataType: varchar2
            }
        )

        column USER_INITIALS (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: USER_INITIALS
                dataType: varchar2
            }
        )

        column USER_NAME (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 50
            }
            source {
                databaseColumn: USER_NAME
                dataType: varchar2
            }
        )

